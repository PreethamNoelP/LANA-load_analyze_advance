# ─────────────────────────────────────────────────────────────────────────────
# LANA Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose: "ollama"  or  "openai_compat"
LLM_PROVIDER=ollama

# Model name used by the selected provider
# Ollama examples    : llama3.1:8b | mistral:7b | phi3:mini | gemma2:2b | qwen2.5:7b
# OpenAI-compat ex.  : llama-3.1-8b-instant (Groq) | llama-3-8b (Together.ai)
LLM_MODEL=llama3.1:8b

# Generation parameters
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# ── Ollama ────────────────────────────────────────────────────────────────────
# URL where Ollama is running (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# ── OpenAI-compatible API (Groq, LM Studio, Together.ai, Fireworks, etc.) ─────
# OPENAI_COMPAT_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_COMPAT_API_KEY=gsk_...
# LLM_PROVIDER=openai_compat
# LLM_MODEL=llama-3.1-8b-instant